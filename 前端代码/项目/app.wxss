page {
  background-color: #EEF6F3;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
}

.container {
  padding: 0 36rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #DCE9E5;
}

.flex { display: flex; }
.flex-column { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { justify-content: space-between; }
.flex-1 { flex: 1; }
.text-center { text-align: center; }
.text-gray { color: #999999; }
.text-primary { color: #15B889; }
.text-primary-dark { color: #078867; }
.text-blue { color: #3B82F6; }
.text-red { color: #EF5B5B; }
.text-orange { color: #FFB547; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 26rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }
.font-bold { font-weight: 600; }
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mt-10 { margin-top: 10rpx; }
.mb-10 { margin-bottom: 10rpx; }
.p-20 { padding: 20rpx; }
.radius-8 { border-radius: 8rpx; }
.radius-16 { border-radius: 16rpx; }
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
button { margin: 0; padding: 0; background: none; border: none; line-height: inherit; }
button::after { border: none; }
.safe-area-bottom { padding-bottom: env(safe-area-inset-bottom); }
.scroll-view { height: 100%; }
.btn-primary { background-color: #15B889; color: #FFFFFF; border-radius: 32rpx; font-size: 28rpx; font-weight: 500; padding: 16rpx 48rpx; text-align: center; }
.btn-secondary { background-color: #DCE9E5; color: #078867; border-radius: 32rpx; font-size: 28rpx; font-weight: 500; padding: 16rpx 48rpx; text-align: center; }
.btn-danger { background-color: #EF5B5B; color: #FFFFFF; border-radius: 32rpx; font-size: 28rpx; font-weight: 500; padding: 16rpx 48rpx; text-align: center; }
.btn-text { background: transparent; color: #15B889; font-size: 28rpx; padding: 16rpx; text-align: center; }
.tag { display: inline-block; padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; font-weight: 500; }
.tag-primary { background-color: #DCE9E5; color: #078867; }
.tag-blue { background-color: #E3F2FD; color: #3B82F6; }
.tag-orange { background-color: #FFF3E0; color: #FFB547; }
.tag-red { background-color: #FFEBEE; color: #EF5B5B; }
.tag-small { padding: 2rpx 10rpx; font-size: 20rpx; margin-left: 6rpx; }