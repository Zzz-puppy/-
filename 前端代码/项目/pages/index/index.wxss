.header {
  background-color: #FFFFFF;
  padding: 20rpx 36rpx;
  margin-bottom: 20rpx;
}

.logo-area {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.logo-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #15B889 0%, #078867 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.logo-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-left: 16rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #EEF6F3;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999999;
  margin-left: 16rpx;
}

.banner-area {
  margin-bottom: 20rpx;
}

.banner-swiper {
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #15B889 0%, #078867 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-item.banner-2 {
  background: linear-gradient(135deg, #3B82F6 0%, #1D4ED8 100%);
}

.banner-item.banner-3 {
  background: linear-gradient(135deg, #FFB547 0%, #F59E0B 100%);
}

.banner-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.category-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #DCE9E5;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999999;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #EEF6F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  color: #15B889;
  font-size: 32rpx;
  font-weight: 600;
}

.category-name {
  font-size: 24rpx;
  color: #666666;
}

.goods-list {
  padding-bottom: 20rpx;
}

.goods-card {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #DCE9E5;
}

.goods-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.image-placeholder {
  background: linear-gradient(135deg, #DCE9E5 0%, #EEF6F3 100%);
  color: #078867;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.goods-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.goods-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #EF5B5B;
}

.seller-info {
  display: flex;
  align-items: center;
}

.seller-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  background-color: #DCE9E5;
  color: #078867;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.seller-name {
  font-size: 22rpx;
  color: #666666;
  margin-left: 8rpx;
}

.credit-score {
  font-size: 22rpx;
  color: #15B889;
  margin-left: 8rpx;
}

.publish-time {
  font-size: 24rpx;
  color: #999999;
}

.list-empty {
  background-color: #FFFFFF;
  border: 2rpx solid #DCE9E5;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  margin-bottom: 20rpx;
  text-align: center;
  color: #999999;
  font-size: 26rpx;
}