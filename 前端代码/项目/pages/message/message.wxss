.tabs {
  display: flex;
  background-color: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 0 36rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  position: relative;
}

.tab-item text {
  font-size: 30rpx;
  color: #666666;
}

.tab-item.active text {
  color: #15B889;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #15B889;
  border-radius: 2rpx;
}

.badge {
  position: absolute;
  top: 16rpx;
  right: 30rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #EF5B5B;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.tab-content {
  flex: 1;
}

.chat-list {
  padding: 20rpx 36rpx;
}

.chat-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
  border: 2rpx solid #DCE9E5;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  background-color: #DCE9E5;
  color: #078867;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

.chat-info {
  flex: 1;
  margin-left: 20rpx;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.chat-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.chat-time {
  font-size: 24rpx;
  color: #999999;
}

.chat-content {
  font-size: 26rpx;
  color: #999999;
}

.chat-goods {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #15B889;
}

.chat-item .badge {
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}

.notice-list {
  padding: 20rpx 36rpx;
}

.notice-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #DCE9E5;
}

.notice-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notice-icon text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.notice-icon.order {
  background-color: #3B82F6;
}

.notice-icon.system {
  background-color: #15B889;
}

.notice-icon.comment {
  background-color: #FFB547;
}

.notice-info {
  flex: 1;
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.notice-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.notice-time {
  font-size: 24rpx;
  color: #999999;
}

.notice-content {
  font-size: 26rpx;
  color: #999999;
}

.notice-arrow {
  margin-left: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.empty-state text {
  margin-top: 20rpx;
}

.notice-item.unread {
  background-color: #f0f7ff;
  border-color: #b3d4ff;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #EF5B5B;
  margin-left: 16rpx;
  flex-shrink: 0;
}