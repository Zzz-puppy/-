.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: block;
}

.required {
  color: #EF5B5B;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: #EEF6F3;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 240rpx;
  background-color: #EEF6F3;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  display: block;
  position: relative;
  z-index: 1;
}

.textarea-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.upload-item {
  position: relative;
  width: calc(33.33% - 14rpx);
  height: 200rpx;
}

.upload-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
}

.upload-btn {
  width: calc(33.33% - 14rpx);
  height: 200rpx;
  border: 2rpx dashed #DCE9E5;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
  font-size: 24rpx;
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background-color: #EEF6F3;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
}

.price-input-wrap {
  display: flex;
  align-items: center;
  background-color: #EEF6F3;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 88rpx;
}

.price-symbol {
  font-size: 36rpx;
  color: #EF5B5B;
  font-weight: 600;
}

.price-input {
  flex: 1;
  height: 100%;
  font-size: 36rpx;
  color: #EF5B5B;
  font-weight: 600;
  margin-left: 8rpx;
}

.checkbox-group {
  display: flex;
  gap: 32rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #DCE9E5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.checkbox-item.checked .checkbox {
  background-color: #15B889;
  border-color: #15B889;
}

.checkbox-item text {
  font-size: 28rpx;
  color: #333333;
}

.submit-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(135deg, #15B889 0%, #078867 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 10;
}