.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: #EEF6F3;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #CCCCCC;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.go-home-btn {
  padding: 16rpx 60rpx;
  background: linear-gradient(135deg, #15B889, #0D9E6F);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.favorite-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
}

.fav-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.fav-image-placeholder {
  background: linear-gradient(135deg, #DCE9E5, #EEF6F3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #15B889;
  font-weight: 600;
}

.fav-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.fav-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.fav-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.fav-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #EF5B5B;
}

.fav-seller {
  font-size: 24rpx;
  color: #999999;
}

.fav-delete {
  flex-shrink: 0;
  padding: 16rpx;
}

.fav-delete text {
  font-size: 36rpx;
  color: #EF5B5B;
}