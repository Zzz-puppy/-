.tabs {
  display: flex;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  position: relative;
}

.tab-item text {
  font-size: 28rpx;
  color: #666666;
}

.tab-item.active text {
  color: #576b95;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #576b95;
  border-radius: 2rpx;
}

.goods-list {
  padding: 20rpx;
}

.goods-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.goods-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-title {
  font-size: 28rpx;
  color: #333333;
}

.goods-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #e74c3c;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999999;
}

.goods-status {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.goods-status.on-sale {
  background-color: #e8f5e9;
  color: #27ae60;
}

.goods-status.sold {
  background-color: #f5f5f5;
  color: #999999;
}

.goods-status.off-sale {
  background-color: #fff3e0;
  color: #e65100;
}

.goods-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border: 2rpx solid #dddddd;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
}

.action-btn.delete {
  border-color: #e74c3c;
  color: #e74c3c;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.empty-state text {
  margin-top: 20rpx;
}

.empty-btn {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background-color: #576b95;
  border-radius: 32rpx;
  color: #ffffff;
  font-size: 28rpx;
}