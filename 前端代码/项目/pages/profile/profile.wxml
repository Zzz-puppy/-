<view class="container">
  <view class="user-card">
    <view class="user-info" bindtap="goEditProfile">
      <image wx:if="{{userInfo.avatar}}" class="avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-placeholder">
        <text>{{userInitial}}</text>
      </view>
      <view class="user-detail">
        <view class="user-header">
          <text class="user-name">{{isLoggedIn ? (userInfo.nickname || '微信用户') : '点击登录'}}</text>
          <text class="tag tag-primary" wx:if="{{userInfo.isCertified}}">已认证</text>
          <text class="tag tag-admin" wx:if="{{userInfo.role === 'admin'}}">管理</text>
        </view>
        <view class="user-meta">
          <text class="user-id">{{isLoggedIn ? ('学号: ' + (userInfo.studentId || '未绑定')) : '登录后查看个人数据'}}</text>
          <text class="grade" wx:if="{{isLoggedIn && userInfo.grade}}">{{userInfo.grade}}</text>
        </view>
        <view class="user-meta-row" wx:if="{{isLoggedIn}}">
          <text class="credit-score">信用分: {{userInfo.creditScore || 0}}</text>
        </view>
      </view>
      <icon type="arrowright" size="20" color="#FFFFFF" />
    </view>
    
    <view class="user-stats">
      <view class="stat-item" bindtap="goMyPublish">
        <text class="stat-value">{{stats.publishCount}}</text>
        <text class="stat-label">我的发布</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="goFavorites">
        <text class="stat-value">{{userInfo.favoriteCount || 0}}</text>
        <text class="stat-label">我的收藏</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="goOrders">
        <text class="stat-value">{{stats.orderCount}}</text>
        <text class="stat-label">我的订单</text>
      </view>
    </view>
  </view>

  <view class="card login-card" wx:if="{{!isLoggedIn}}">
    <text class="login-title">一键登录后使用完整功能</text>
    <view class="btn-primary login-btn" bindtap="login">
      <text>一键登录</text>
    </view>
  </view>

  <view class="card">
    <view class="order-section" bindtap="goOrders">
      <view class="section-header">
        <text class="section-title">我的订单</text>
        <view class="section-more">
          <text>查看全部</text>
          <icon type="arrowright" size="16" color="#999" />
        </view>
      </view>
      <view class="order-tabs">
        <view class="order-tab" bindtap="goOrders" data-status="all">
          <view class="order-icon">
            <icon type="success" size="32" color="#15B889" />
          </view>
          <text class="order-tab-text">全部</text>
          <view class="badge" wx:if="{{orderBadge.all > 0}}">{{orderBadge.all}}</view>
        </view>
        <view class="order-tab" bindtap="goOrders" data-status="pending">
          <view class="order-icon">
            <icon type="waiting" size="32" color="#FFB547" />
          </view>
          <text class="order-tab-text">待确认</text>
          <view class="badge" wx:if="{{orderBadge.pending > 0}}">{{orderBadge.pending}}</view>
        </view>
        <view class="order-tab" bindtap="goOrders" data-status="review">
          <view class="order-icon">
            <icon type="success_no_circle" size="32" color="#3B82F6" />
          </view>
          <text class="order-tab-text">已完成</text>
          <view class="badge" wx:if="{{orderBadge.review > 0}}">{{orderBadge.review}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="menu-list">
      <!-- 管理系统入口（登录后才显示） -->
      <view class="menu-item" bindtap="goAdmin" wx:if="{{isLoggedIn}}">
        <view class="menu-icon orange">
          <icon type="warn" size="28" color="#FFFFFF" />
        </view>
        <text class="menu-text">管理系统入口</text>
        <text class="menu-badge" wx:if="{{userInfo.role === 'admin'}}">管理</text>
        <icon type="arrowright" size="18" color="#999" />
      </view>
      <!-- 校园认证 -->
      <view class="menu-item" bindtap="certify" wx:if="{{isLoggedIn}}">
        <view class="menu-icon {{certificationStatus === 'rejected' ? 'red' : 'green'}}">
          <icon type="success" size="28" color="#FFFFFF" />
        </view>
        <text class="menu-text" wx:if="{{userInfo.isCertified}}">已认证（{{userInfo.studentId || ''}}）</text>
        <text class="menu-text" wx:elif="{{certificationStatus === 'pending'}}">认证审核中</text>
        <text class="menu-text" wx:elif="{{certificationStatus === 'rejected'}}">认证被驳回（点击重新申请）</text>
        <text class="menu-text" wx:else>校园认证</text>
        <icon type="arrowright" size="18" color="#999" />
      </view>
      <view class="menu-item" bindtap="goMyWanted" wx:if="{{isLoggedIn}}">
        <view class="menu-icon yellow">
          <icon type="search" size="28" color="#FFFFFF" />
        </view>
        <text class="menu-text">我的求购</text>
        <icon type="arrowright" size="18" color="#999" />
      </view>
      <view class="menu-item" bindtap="clearLogin">
        <view class="menu-icon blue">
          <icon type="cancel" size="28" color="#FFFFFF" />
        </view>
        <text class="menu-text">清除登录信息</text>
        <icon type="arrowright" size="18" color="#999" />
      </view>
    </view>
  </view>
</view>