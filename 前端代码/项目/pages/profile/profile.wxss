.user-card {
  background: linear-gradient(135deg, #15B889 0%, #078867 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  color: #FFFFFF;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-placeholder {
  background-color: rgba(255, 255, 255, 0.24);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 600;
}

.user-detail {
  flex: 1;
  margin-left: 24rpx;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-right: 12rpx;
}

.tag {
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  vertical-align: middle;
}

.tag-primary {
  background-color: rgba(255, 255, 255, 0.3);
}

.tag-admin {
  background-color: rgba(255, 152, 0, 0.7);
}

.user-meta {
  display: flex;
  gap: 24rpx;
}

.user-id {
  font-size: 26rpx;
  opacity: 0.8;
}

.credit-score {
  font-size: 26rpx;
  opacity: 0.8;
}

.grade {
  font-size: 24rpx;
  opacity: 0.7;
}

.user-meta-row {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 24rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
  display: block;
}

.stat-divider {
  width: 2rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

.login-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.login-title {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.login-btn {
  flex-shrink: 0;
  padding: 14rpx 32rpx;
}

.order-section {
  padding: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid #DCE9E5;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999999;
}

.order-tabs {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.order-icon {
  width: 72rpx;
  height: 72rpx;
  background-color: #EEF6F3;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.order-tab-text {
  font-size: 24rpx;
  color: #666666;
}

.order-tab .badge {
  top: -8rpx;
  right: -8rpx;
}

.badge {
  position: absolute;
  min-width: 28rpx;
  height: 28rpx;
  background-color: #EF5B5B;
  border-radius: 14rpx;
  font-size: 18rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.menu-list {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #DCE9E5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon.blue {
  background-color: #3B82F6;
}

.menu-icon.yellow {
  background-color: #F5A623;
}

.menu-icon.orange {
  background-color: #F57C00;
}

.menu-icon.red {
  background-color: #EF5B5B;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-badge {
  background-color: #EF5B5B;
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
}