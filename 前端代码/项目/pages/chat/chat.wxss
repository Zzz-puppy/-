.chat-page {
  min-height: 100vh;
  background-color: #EEF6F3;
  display: flex;
  flex-direction: column;
}

.message-list {
  flex: 1;
  height: calc(100vh - 112rpx);
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}

.goods-tip {
  background-color: #FFFFFF;
  border: 2rpx solid #DCE9E5;
  border-radius: 12rpx;
  padding: 20rpx;
  color: #666666;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.message-row.mine {
  flex-direction: row-reverse;
}

.message-row.system {
  justify-content: center;
}

.system-message {
  background-color: rgba(0, 0, 0, 0.08);
  color: #666666;
  border-radius: 8rpx;
  padding: 8rpx 18rpx;
  font-size: 24rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #DCE9E5;
  color: #078867;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.bubble {
  max-width: 520rpx;
  margin-left: 16rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 18rpx 20rpx 12rpx;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
}

.mine .bubble {
  margin-left: 0;
  margin-right: 16rpx;
  background-color: #15B889;
  color: #FFFFFF;
}

.time {
  display: block;
  margin-top: 8rpx;
  color: #999999;
  font-size: 22rpx;
}

.mine .time {
  color: rgba(255, 255, 255, 0.8);
}

.input-bar {
  height: 112rpx;
  background-color: #FFFFFF;
  border-top: 2rpx solid #DCE9E5;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
}

.message-input {
  flex: 1;
  height: 72rpx;
  background-color: #EEF6F3;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background-color: #15B889;
  color: #FFFFFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}