.search-panel {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
}

.search-box {
  flex: 1;
  height: 76rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #DCE9E5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  margin-left: 12rpx;
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-btn {
  width: 112rpx;
  height: 76rpx;
  border-radius: 12rpx;
  background-color: #15B889;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.sort-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.sort-item {
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #666666;
  background-color: #FFFFFF;
  border: 2rpx solid #DCE9E5;
}

.sort-item.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #15B889 0%, #078867 100%);
  border-color: #15B889;
}

.result-meta {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.goods-list {
  padding-bottom: 20rpx;
}

.goods-card {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #DCE9E5;
}

.goods-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.image-placeholder {
  background: linear-gradient(135deg, #DCE9E5 0%, #EEF6F3 100%);
  color: #078867;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.goods-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.goods-desc {
  font-size: 24rpx;
  color: #999999;
  margin: 8rpx 0;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.goods-price {
  font-size: 34rpx;
  font-weight: 600;
  color: #EF5B5B;
}

.publish-time {
  font-size: 24rpx;
  color: #999999;
}

.seller-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
}

.seller-name {
  font-size: 24rpx;
  color: #666666;
}

.credit-score {
  font-size: 22rpx;
  color: #F5A623;
}