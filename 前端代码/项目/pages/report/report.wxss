.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: #EEF6F3;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.type-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.type-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border: 2rpx solid #EEEEEE;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.type-item.active {
  border-color: #15B889;
  background-color: #F0FAF5;
}

.type-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #CCCCCC;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-item.active .type-radio {
  border-color: #15B889;
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #15B889;
}

.type-info {
  flex: 1;
}

.type-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
}

.type-desc {
  font-size: 24rpx;
  color: #999999;
}

.desc-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  padding: 16rpx;
  background-color: #FAFAFA;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  padding: 0 8rpx;
}

.submit-area {
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #EF5B5B, #E74C3C);
  color: #FFFFFF;
  border-radius: 48rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.tip {
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}