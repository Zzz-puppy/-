.page-container {
  min-height: 100vh;
  background-color: #EEF6F3;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #15B889 0%, #078867 100%);
  padding: 40rpx 32rpx;
  color: #FFFFFF;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.tab-bar {
  display: flex;
  background: #FFFFFF;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #15B889;
  font-weight: 600;
  border-bottom: 4rpx solid #15B889;
}

.tab-badge {
  position: absolute;
  top: 12rpx;
  right: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #EF5B5B;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.tab-content {
  padding: 20rpx;
}

.content-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.content-header {
  padding: 24rpx;
  border-bottom: 2rpx solid #DCE9E5;
}

.content-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.empty-state {
  padding: 80rpx 0;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.cert-item {
  padding: 24rpx;
  border-bottom: 2rpx solid #DCE9E5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cert-item:last-child {
  border-bottom: none;
}

.cert-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.cert-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.cert-student-id {
  font-size: 24rpx;
  color: #666666;
}

.cert-time {
  font-size: 22rpx;
  color: #999999;
}

.cert-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.btn-approve {
  background-color: #15B889;
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  border: none;
  line-height: 1.5;
}

.btn-reject {
  background-color: #EF5B5B;
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  border: none;
  line-height: 1.5;
}

.user-item {
  padding: 24rpx;
  border-bottom: 2rpx solid #DCE9E5;
}

.user-item:last-child {
  border-bottom: none;
}

.user-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.user-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.user-item-role {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.role-admin {
  background-color: #FFF3E0;
  color: #F57C00;
}

.role-user {
  background-color: #E8F5E9;
  color: #388E3C;
}

.status-normal {
  background-color: #E8F5E9;
  color: #388E3C;
}

.status-banned {
  background-color: #FFEBEE;
  color: #D32F2F;
}

.user-item-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.user-item-actions {
  display: flex;
  gap: 16rpx;
}

.btn-small {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  border: none;
  line-height: 1.5;
}

.btn-credit-up {
  background-color: #E8F5E9;
  color: #2E7D32;
}

.btn-credit-down {
  background-color: #FFEBEE;
  color: #C62828;
}

.btn-ban {
  background-color: #FFF3E0;
  color: #E65100;
}

.user-list-scroll, .item-list-scroll {
  max-height: 1000rpx;
}